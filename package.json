{
  "name": "workout-tracker",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "start": "node index.js",
    "format": "prettier --write .",
    "lint": "eslint . --no-warn-ignored --max-warnings=0",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,json,md}": [
      "prettier --write"
    ],
    "*.js": [
      "eslint --fix"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.5.0",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "prettier": "^3.8.4"
  }
}
